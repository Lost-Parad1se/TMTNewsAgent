# LLM provider configuration.
# Supported LLM_PROVIDER values: mock, gemini, qwen, deepseek, glm, openai-compatible
LLM_PROVIDER=mock
LLM_FALLBACK_TO_MOCK=true
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60

# Provider-specific API keys. Set one matching LLM_PROVIDER.
GEMINI_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
ZHIPUAI_API_KEY=

# Optional provider-specific model overrides.
GEMINI_MODEL=gemini-2.5-flash
QWEN_MODEL=qwen-plus
DEEPSEEK_MODEL=deepseek-v4-flash
GLM_MODEL=glm-5.1

# Generic OpenAI-compatible override. Useful for custom gateways.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional search provider placeholders. The MVP falls back to mock results.
SEARCH_PROVIDER=mock
TAVILY_API_KEY=
SERPAPI_API_KEY=
BING_SEARCH_API_KEY=
SOGOU_WECHAT_API_KEY=

# Runtime paths.
SQLITE_PATH=data/processed/tmt_news_agent.db
